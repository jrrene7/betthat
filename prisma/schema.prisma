// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid()) @map("_id")
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  balance       Int       @default(1000)
  accounts      Account[]
  sessions      Session[]
  video         Video[]

  posts         Post[]         @relation("PostAuthor")
  postLikes     PostLike[]
  postComments  PostComment[]
  betsCreated   Bet[]          @relation("BetCreator")
  betsReceived  Bet[]          @relation("BetOpponent")
  betsWon       Bet[]          @relation("BetWinner")
  betVotes      BetVote[]
  challenges    Challenge[]    @relation("ChallengeCreator")
  challengesWon Challenge[]    @relation("ChallengeWinner")
  challengeParticipations ChallengeParticipant[]
  submissions     ChallengeSubmission[]
  betSubmissions  BetSubmission[]
  submissionVotes SubmissionVote[]
  transactions    PointTransaction[]
  notifications          Notification[] @relation("NotificationRecipient")
  notificationsTriggered Notification[] @relation("NotificationActor")
  followers     Follow[]       @relation("followings")
  followings    Follow[]       @relation("followers")
  checked       Boolean        @default(false)

  @@fulltext([name])
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Video {
  id        String         @id @default(cuid()) @map("_id")
  title     String
  videoUrl  String
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  width     Int
  height    Int
  thumbnail String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt()
  posts               Post[]
  challengeSubmissions ChallengeSubmission[] @relation("ChallengeSubmissionVideo")
  betSubmissions       BetSubmission[]       @relation("BetSubmissionVideo")

  @@fulltext([title])
}

model Follow {
  id          String @id @default(cuid()) @map("_id")
  followerId  String
  followingId String
  follower    User   @relation("followers", fields: [followerId], references: [id])
  following   User   @relation("followings", fields: [followingId], references: [id])
}

model Post {
  id          String        @id @default(cuid()) @map("_id")
  title       String?
  content     String
  isPublished Boolean       @default(true)
  authorId    String
  author      User          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  videoId     String?
  video       Video?        @relation(fields: [videoId], references: [id], onDelete: SetNull)
  imageUrl    String?
  likes       PostLike[]
  comments    PostComment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt()

  @@index([authorId])
  @@index([videoId])
}

model PostLike {
  id     String @id @default(cuid()) @map("_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid()) @map("_id")
  content   String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([postId])
  @@index([userId])
}

model Bet {
  id           String             @id @default(cuid()) @map("_id")
  title        String
  description  String?
  status       BetStatus          @default(PENDING)
  wagerAmount  Int                @default(0)
  visibility   Visibility         @default(PUBLIC)
  creatorId    String
  creator      User               @relation("BetCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  opponentId   String
  opponent     User               @relation("BetOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  winnerId     String?
  winner       User?              @relation("BetWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  challengeId  String?
  challenge    Challenge?         @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  votes           BetVote[]
  betSubmissions  BetSubmission[]
  transactions    PointTransaction[]
  dueAt        DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt()

  @@index([creatorId])
  @@index([opponentId])
  @@index([winnerId])
  @@index([challengeId])
  @@index([status])
}

model BetVote {
  id         String   @id @default(cuid()) @map("_id")
  betId      String
  bet        Bet      @relation(fields: [betId], references: [id], onDelete: Cascade)
  voterId    String
  voter      User     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  votedForId String
  createdAt  DateTime @default(now())

  @@unique([betId, voterId])
  @@index([betId])
  @@index([voterId])
}

model Challenge {
  id           String                 @id @default(cuid()) @map("_id")
  title        String
  description  String?
  status       ChallengeStatus        @default(OPEN)
  visibility   Visibility             @default(PUBLIC)
  wagerAmount  Int                    @default(0)
  creatorId    String
  creator      User                   @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  winnerId     String?
  winner       User?                  @relation("ChallengeWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  participants ChallengeParticipant[]
  bets         Bet[]
  submissions  ChallengeSubmission[]
  startsAt     DateTime?
  endsAt       DateTime?
  completedAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt()

  @@index([creatorId])
  @@index([status])
  @@index([winnerId])
}

model ChallengeParticipant {
  id          String    @id @default(cuid()) @map("_id")
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([challengeId, userId])
  @@index([userId])
}

model ChallengeSubmission {
  id          String           @id @default(cuid()) @map("_id")
  challengeId String
  challenge   Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String?
  imageUrl    String?
  videoId     String?
  video       Video?           @relation("ChallengeSubmissionVideo", fields: [videoId], references: [id], onDelete: SetNull)
  votes       SubmissionVote[]
  status      SubmissionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt()

  @@index([challengeId])
  @@index([userId])
}

model BetSubmission {
  id        String   @id @default(cuid()) @map("_id")
  betId     String
  bet       Bet      @relation(fields: [betId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?
  imageUrl  String?
  videoId   String?
  video     Video?   @relation("BetSubmissionVideo", fields: [videoId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([betId])
  @@index([userId])
}

model SubmissionVote {
  id           String              @id @default(cuid()) @map("_id")
  submissionId String
  submission   ChallengeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voterId      String
  voter        User                @relation(fields: [voterId], references: [id], onDelete: Cascade)
  approved     Boolean
  createdAt    DateTime            @default(now())

  @@unique([submissionId, voterId])
  @@index([submissionId])
  @@index([voterId])
}

model PointTransaction {
  id          String          @id @default(cuid()) @map("_id")
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        TransactionType
  betId       String?
  bet         Bet?            @relation(fields: [betId], references: [id], onDelete: SetNull)
  description String?
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([betId])
}

enum BetStatus {
  PENDING
  ACCEPTED
  DECLINED
  ACTIVE
  DISPUTED
  SETTLED
  CANCELLED
}

enum ChallengeStatus {
  OPEN
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model Notification {
  id         String           @id @default(cuid()) @map("_id")
  userId     String
  user       User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type       NotificationType
  entityId   String?
  entityType String?
  message    String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([actorId])
}

enum NotificationType {
  BET_RECEIVED
  CHALLENGE_INVITED
  CHALLENGE_JOINED
  BET_ACCEPTED
  BET_DECLINED
  CHALLENGE_COMPLETED
}

enum TransactionType {
  BET_PLACED
  BET_WON
  BET_LOST
  BET_REFUNDED
  CHALLENGE_ENTRY
  CHALLENGE_WON
  CHALLENGE_REFUNDED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}
